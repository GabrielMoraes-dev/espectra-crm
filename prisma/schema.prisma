// Prisma schema — CRM Interno Espectra

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum EtapaLead {
  NOVO
  PRIMEIRO_CONTATO
  RESPONDENDO
  REUNIAO
  PROPOSTA_ENVIADA
  NEGOCIACAO
  FECHADO
  PERDIDO
}

enum StatusCliente {
  EM_PRODUCAO
  EM_REVISAO
  PUBLICADO
  FINALIZADO
}

enum EtapaProjeto {
  BRIEFING
  DESIGN
  DESENVOLVIMENTO
  REVISAO
  PUBLICADO
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
}

enum StatusTarefa {
  A_FAZER
  EM_ANDAMENTO
  CONCLUIDA
}

// ---------- Models ----------

model MembroEquipe {
  id               String   @id @default(cuid())
  nome             String
  cargo            String
  telefone         String?
  email            String?
  foto             String?
  responsabilidades String  // armazenado como JSON string de string[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clientes  Cliente[]
  projetos  Projeto[]
  tarefas   Tarefa[]
}

model Usuario {
  id               String    @id @default(cuid())
  nome             String
  email            String    @unique
  passwordHash     String
  tentativasFalhas Int       @default(0)
  bloqueadoAte     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Registra tentativas de login erradas por IP — camada extra além do bloqueio
// por conta, já que aquele sozinho não impede um ataque distribuído por vários IPs.
model TentativaLoginIp {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

// Rate limit genérico por IP para endpoints públicos sem login (upload, formulários
// de briefing/pesquisa) — mesma ideia do TentativaLoginIp, mas reutilizável por ação.
model TentativaAcaoIp {
  id        String   @id @default(cuid())
  acao      String
  ip        String
  createdAt DateTime @default(now())

  @@index([acao, ip, createdAt])
}

model Lead {
  id             String    @id @default(cuid())
  nome           String
  empresa        String?
  whatsapp       String?
  instagram      String?
  email          String?
  origem         String?
  valorEstimado  Float?
  observacoes    String?
  etapa          EtapaLead @default(NOVO)
  clienteId      String?   @unique
  cliente        Cliente?  @relation(fields: [clienteId], references: [id])
  linkCopiadoEm  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  briefings      Briefing[]
  briefingsIniciais BriefingInicial[]
}

model BriefingInicial {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  nome         String
  profissao    String
  email        String
  apresentacao String
  fotosUrls    String
  createdAt    DateTime @default(now())

  @@index([leadId])
}

model Cliente {
  id               String        @id @default(cuid())
  nome             String
  empresa          String?
  whatsapp         String?
  instagram        String?
  email            String?       @unique
  site             String?
  cidade           String?
  estado           String?
  nicho            String?
  planoContratado  String?
  valor            Float?
  contratoUrl      String?
  contratoAutentiqueId String?   @unique
  cpfCnpj          String?
  responsavelId    String?
  responsavel      MembroEquipe? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  dataEntrada      DateTime      @default(now())
  prazo            DateTime?
  status           StatusCliente @default(EM_PRODUCAO)
  observacoes      String?
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lead             Lead?
  timeline         TimelineEvent[]
  projetos         Projeto[]
  pagamentos       Pagamento[]
  fotos            FotoCliente[]
  briefings        Briefing[]
  pesquisas        PesquisaSatisfacao[]
  tarefas          Tarefa[]

  @@index([responsavelId])
}

model FotoCliente {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())

  @@index([clienteId])
}

model Briefing {
  id                   String   @id @default(cuid())
  leadId               String?
  lead                 Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clienteId            String?
  cliente              Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  // 1. Identificação
  nome                 String
  profissao            String
  cidade               String
  estado               String?
  email                String
  whatsapp             String
  instagram            String?
  cpfCnpj              String?
  registroProfissional String?

  // 2. Como você quer ser percebido
  apresentacao         String
  historia             String
  especialidades       String
  numeroDestaque       String?

  // 3. Diferenciais e proposta de valor
  diferenciais         String
  motivoProcura        String
  servicos             String
  atendimento          String
  ondeAtende           String?
  enderecoFisico       String?
  valoresServicos      String?
  dominio              String?
  faqAgendamento       String?
  faqAntesConsulta     String?
  faqCancelamento      String?
  faqHorarios          String?

  // 4. Objetivo da landing page
  objetivo             String?
  cta                  String?

  // 5. Materiais e arquivos — armazenados como JSON string de string[]
  depoimentosUrls      String?
  fotosUrls            String?
  arquivosGeraisUrls   String

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([leadId])
  @@index([clienteId])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  data        DateTime @default(now())
  titulo      String
  descricao   String?
  createdAt   DateTime @default(now())

  @@index([clienteId])
}

model Projeto {
  id            String       @id @default(cuid())
  clienteId     String
  cliente       Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  prazo         DateTime?
  responsavelId String?
  responsavel   MembroEquipe? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  status        EtapaProjeto @default(BRIEFING)
  observacoes   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([clienteId])
  @@index([responsavelId])
}

model Pagamento {
  id             String   @id @default(cuid())
  clienteId      String
  cliente        Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  valor          Float
  pago           Boolean  @default(false)
  formaPagamento String?
  desconto       Int?
  data           DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([clienteId])
}

model PesquisaSatisfacao {
  id          String   @id @default(cuid())
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  qualidade   Int
  comunicacao Int
  prazos      Int
  atendimento Int
  nota        Int
  comentario  String?
  createdAt   DateTime @default(now())

  @@index([clienteId])
}

model PagamentoSemMatch {
  id        String   @id @default(cuid())
  nome      String
  email     String
  telefone  String
  valor     Float
  resolvido Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Tarefa {
  id            String            @id @default(cuid())
  titulo        String
  descricao     String?
  responsavelId String?
  responsavel   MembroEquipe?     @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  clienteId     String?
  cliente       Cliente?          @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  prazo         DateTime?
  prioridade    PrioridadeTarefa  @default(MEDIA)
  status        StatusTarefa      @default(A_FAZER)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([responsavelId])
  @@index([clienteId])
}

model SOP {
  id        String   @id @default(cuid())
  titulo    String
  categoria String
  conteudo  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model LinkInterno {
  id        String   @id @default(cuid())
  nome      String
  url       String
  icone     String?
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
}

model ConfiguracaoEmpresa {
  id                    String  @id @default(cuid())
  nomeEmpresa           String  @default("Espectra")
  logoUrl               String?
  sobre                 String?
  tema                  String  @default("dark-navy")
  metaFaturamentoMensal Float?
}

model ActivityLog {
  id            String   @id @default(cuid())
  tipo          String
  descricao     String
  entidadeTipo  String?
  entidadeId    String?
  createdAt     DateTime @default(now())
}
